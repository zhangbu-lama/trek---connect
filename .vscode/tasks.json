{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Server: dev",
      "type": "npm",
      "script": "dev",
      "path": "server",
      "problemMatcher": {
        "owner": "node",
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server running on PORT"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "trekconnect"
      },
      "isBackground": true,
      "runOptions": { "instanceLimit": 1 }
    },
    {
      "label": "Client: dev",
      "type": "npm",
      "script": "dev",
      "path": "Client",
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "trekconnect"
      },
      "isBackground": true,
      "runOptions": { "instanceLimit": 1 }
    },
    {
      "label": "Run Trek Connect (API + Client)",
      "dependsOn": ["Server: dev", "Client: dev"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Install all dependencies",
      "dependsOn": ["Install: server", "Install: Client"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Install: server",
      "type": "npm",
      "script": "install",
      "path": "server",
      "problemMatcher": []
    },
    {
      "label": "Install: Client",
      "type": "npm",
      "script": "install",
      "path": "Client",
      "problemMatcher": []
    }
  ]
}
